{
  "manifest_version": 3,
  "name": "Inline Decryptor",
  "version": "1.0",
  "description": "Per-URL wachtwoorden in een versleutelde kluis, met hoofdwachtwoord en auto-lock.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage", "alarms", "idle", "activeTab"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["i18n.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
